    },
    {
      "source": "/feed.json",
      "destination": "https://hxihntmxawwzeqvwbjfi.supabase.co/functions/v1/json-feed"
    },
    {
      "source": "/feed/:vertical.xml",
      "destination": "https://hxihntmxawwzeqvwbjfi.supabase.co/functions/v1/rss-feed?vertical=:vertical"
    },
    {
      "source": "/feed/:vertical.json",
      "destination": "https://hxihntmxawwzeqvwbjfi.supabase.co/functions/v1/json-feed?vertical=:vertical"
    },
    {
      "source": "/api/og-proxy",
      "destination": "https://hxihntmxawwzeqvwbjfi.supabase.co/functions/v1/og-meta"
    },
    {
      "source": "/:path(intel|rwas|data-feeds|api-documentation|showcase|whitepaper|super-cloud|cut-token|security|rto|rto-deck|investors|deck|corporate-deck|path-to-1b|news|services/:sub*|web3ai/:sub*|rwas/:sub*|blog/:sub*|legal)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(WhatsApp|facebookexternalhit|Facebot|Twitterbot|Slackbot|LinkedInBot|LinkedIn|linkedinbot|linkedin|Discordbot|TelegramBot|Telegram|TelegramBotAPI|bot\\.telegram|Googlebot|bingbot|Applebot|Pinterestbot|Redditbot|Tumblr|Viber|Snapchat|Skype|vkShare|W3C_Validator|Embedly|Quora|outbrain|Pinterest|Mastodon|ia_archiver|MJ12bot|Baiduspider|YandexBot|DuckDuckBot|Sogou|Exabot|SemrushBot|AhrefsBot|PetalBot|MegaIndex|DataForSeoBot|ZoominfoBot|SeekportBot|Neevabot|ICC-Crawler).*"
